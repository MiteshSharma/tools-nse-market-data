{
  "name": "@ethosagent/tools-nse-market-data",
  "version": "0.1.4",
  "description": "NSE India market data tools for Ethos AI agents — local SQLite storage, daily sync via Yahoo Finance, watchlist management, screener, and technical indicators.",
  "keywords": [
    "nse",
    "india",
    "stock-market",
    "market-data",
    "sqlite",
    "ethos",
    "ai-agent",
    "trading",
    "technical-analysis",
    "yahoo-finance"
  ],
  "homepage": "https://github.com/MiteshSharma/tools-nse-market-data",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MiteshSharma/tools-nse-market-data.git"
  },
  "bugs": "https://github.com/MiteshSharma/tools-nse-market-data/issues",
  "license": "MIT",
  "author": "Mitesh Sharma",
  "type": "module",
  "packageManager": "npm@10.8.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "nse-market-data": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepublishOnly": "npm run check && npm run build",
    "postinstall": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "12.10.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.19.19",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "peerDependencies": {
    "@ethosagent/types": ">=0.4.0"
  },
  "peerDependenciesMeta": {
    "@ethosagent/types": {
      "optional": true
    }
  }
}
